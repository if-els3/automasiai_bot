{
  "name": "Automated Threat Triage Bot",
  "dockerComposeFile": "docker-compose.yml",
  "service": "n8n",
  "workspaceFolder": "/workspaces/automasiai_bot",
  "forwardPorts": [5678],
  "portsAttributes": {
    "5678": {
      "label": "n8n Workflow Editor",
      "onAutoForward": "openBrowser"
